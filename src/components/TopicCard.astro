---
import {
  BrainCircuit,
  Network,
  Brain,
  Rocket,
  Search,
  Settings,
  BookOpen,
  Lightbulb,
  Cpu,
  FlaskConical,
  Microscope,
  ChartLine,
  Code2,
  Sparkles,
  Sigma,
  Zap,
  DatabaseZap,
  TreePine,
  Eye,
  MessageSquare,
  type LucideProps,
} from "@lucide/astro";

type LucideComponent = (_props: LucideProps) => any;

const ICONS: Record<string, LucideComponent> = {
  BrainCircuit,
  Network,
  Brain,
  Rocket,
  Search,
  Settings,
  BookOpen,
  Lightbulb,
  Cpu,
  FlaskConical,
  Microscope,
  ChartLine,
  Code2,
  Sparkles,
  Sigma,
  Zap,
  DatabaseZap,
  TreePine,
  Eye,
  MessageSquare,
};

interface Props {
  icon: keyof typeof ICONS;
  title: string;
  href?: string;
}

const { icon, title, href } = Astro.props;
const Icon = ICONS[icon];
---

<article class="topic-card">
  {
    Icon && (
      <div class="icon-wrap">
        <Icon size={28} />
      </div>
    )
  }
  <p class="title">
    {href ? <a class="card-link" href={href}>{title}</a> : title}
  </p>
  <div class="body"><slot /></div>
</article>

<style>
  .topic-card {
    position: relative;
    --card-color: var(--sl-color-purple);
    --card-bg: var(--sl-color-purple-low);
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
    border: 1px solid color-mix(in srgb, var(--card-color) 35%, transparent);
    border-radius: 1rem;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--card-bg) 70%, var(--sl-color-bg)) 0%,
      color-mix(in srgb, var(--card-bg) 10%, var(--sl-color-bg)) 100%
    );
    padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
    box-shadow:
      0 1px 0 0 color-mix(in srgb, var(--card-color) 15%, transparent) inset,
      0 4px 24px -4px color-mix(in srgb, var(--card-color) 10%, transparent);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .topic-card:nth-child(4n + 1) {
    --card-color: var(--sl-color-orange);
    --card-bg: var(--sl-color-orange-low);
  }
  .topic-card:nth-child(4n + 2) {
    --card-color: var(--sl-color-purple);
    --card-bg: var(--sl-color-purple-low);
  }
  .topic-card:nth-child(4n + 3) {
    --card-color: var(--sl-color-green);
    --card-bg: var(--sl-color-green-low);
  }
  .topic-card:nth-child(4n + 4) {
    --card-color: var(--sl-color-red);
    --card-bg: var(--sl-color-red-low);
  }

  .topic-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--card-color) 60%, transparent);
    box-shadow:
      0 1px 0 0 color-mix(in srgb, var(--card-color) 22%, transparent) inset,
      0 10px 36px -6px color-mix(in srgb, var(--card-color) 25%, transparent);
  }

  .icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.625rem;
    border: 1px solid var(--card-color);
    background-color: var(--card-bg);
    color: color-mix(in srgb, var(--card-color) 75%, var(--sl-color-gray-3));
    flex-shrink: 0;
  }

  .card-link {
    color: inherit;
    text-decoration: none;
  }

  .card-link::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .title {
    font-weight: 600;
    font-size: var(--sl-text-h4);
    color: var(--sl-color-white);
    line-height: var(--sl-line-height-headings);
    margin: 0;
  }

  .body {
    margin: 0;
    font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
  }
</style>
